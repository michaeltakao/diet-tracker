# ================================================================
# diet-tracker/.envrc  —  direnv-managed shell environment
# Committed to git (no secrets here — they live in .env.local)
# ================================================================

# Load Next.js env file into shell context
# This makes GEMINI_API_KEY, NEXT_PUBLIC_SUPABASE_URL etc. available
# to shell scripts, ct-* commands, and overnight_runner.sh
dotenv_if_exists .env.local

# Project identity — used by ct-* functions and agent scripts
export PROJECT_DIR="$(pwd)"
export PROJECT_NAME="diet-tracker"

# Node — prefer fnm-managed node over system node
if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd 2>/dev/null)" 2>/dev/null || true
fi

# PATH additions local to this project
PATH_add node_modules/.bin
