# ── Gemini (REQUIRED for all AI features) ─────────────────────
# Google AI Studio → API Keys (https://aistudio.google.com/apikey)
# Powers: food-photo analysis, recommendations, coach, habit/weekly reports.
# NEVER prefix with NEXT_PUBLIC_ — server-side use only.
GEMINI_API_KEY=AIza...

# ── Anonymous access policy (PRODUCTION) ──────────────────────
# To avoid silently shipping an open, paid AI endpoint, the AI routes FAIL CLOSED
# in production for anonymous callers unless you opt in one of two ways:
#
#   APP_ACCESS_CODE  — a shared secret. When set, anonymous AI calls must send a
#                      matching `x-access-code` header (the web app prompts once
#                      and stores it locally). Logged-in users bypass it.
#                      RECOMMENDED for any public, no-login deployment.
#   ALLOW_ANONYMOUS  — set to "true" to allow fully open guest access with no code
#                      (rate-limited by IP only). Use only for throwaway/private URLs.
#
# Development (`next dev`) always allows guest access, so local work needs neither.
# Pick a long random string for APP_ACCESS_CODE.
# APP_ACCESS_CODE=
# ALLOW_ANONYMOUS=true

# ── Supabase (OPTIONAL — enables login + cloud sync) ──────────
# The app runs fully in GUEST mode (localStorage only) without these. Set them to
# enable email/Google login, multi-device sync, and server-validated user scoping.
# Project Settings → API in the Supabase dashboard. Run supabase/migrations/*.sql.

# Public URL (safe to commit, always NEXT_PUBLIC_)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key (safe to commit, always NEXT_PUBLIC_)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER prefix with NEXT_PUBLIC_, NEVER commit to git
# Used only in server-side privileged operations (badge checks, weekly reports).
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
